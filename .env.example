# ── Paramètres du serveur FTP/SFTP ──────────────────────────────────────────
# Copier ce fichier en .env et remplir les valeurs réelles.
# Le fichier .env ne doit PAS être versionné (ajouté dans .gitignore).

# Protocole : sftp  ou  ftps
FTP_PROTOCOL=sftp

# Adresse IP ou hostname du serveur
FTP_HOST=192.168.1.100

# Port (22 pour SFTP, 990 pour FTPS implicite, 21 pour FTPS explicite)
FTP_PORT=22

# Identifiants
FTP_USER=mon_login
FTP_PASSWORD=mon_mot_de_passe

# Répertoire distant initial (point d'entrée de la navigation)
FTP_REMOTE_DIR=/home/gatling/results
